# Discord bot token — Developer Portal → Bot → Reset Token (shown once)
BOT_TOKEN=

# Discord application ID — Developer Portal → General Information → Application ID
CLIENT_ID=

# Tenor API key — Google Cloud Console → Credentials (enable Tenor API on the key)
TENOR_KEY=

# Base URL the bot uses to call the API. In a single pod, use localhost.
URL_API=http://localhost:8080

# SQLite database file path. Defaults to ./data/random-gif.db
# DATABASE_PATH=./data/random-gif.db

# HTTP port the API listens on. Defaults to 8080
# PORT=8080
